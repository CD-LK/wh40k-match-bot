            ],
            "primarch": [
              {
                "name": "Canticles of the Omnissiah",
                "abilities": [
                  {
                    "name": "Invocation of Machine Vengeance (Aura)",
                    "description": "At the start of your Command phase, select one unit from your opponent’s army. Until the start of your next Command phase, that enemy unit is your Machine Vengeance target. Each time a model in a friendly ADEPTUS MECHANICUS unit makes an attack that targets your Machine Vengeance target, you can re-roll the Hit roll.",
                    "showAbility": true,
                    "showDescription": true
                  },
                  {
                    "name": "Mantra of Discipline",
                    "description": "This model has the BATTLELINE keyword and has the following ability:\n\nBinharic Courage (Aura): While a friendly ADEPTUS MECHANICUS unit is within 6\" of this model, add 1 to the Objective Control characteristic of models in that unit and each time you take a Battle-shock or Leadership test for that unit, add 1 to that test.",
                    "showAbility": true,
                    "showDescription": true
                  },
                  {
                    "name": "Shroudpsalm (Aura)",
                    "description": "While a friendly ADEPTUS MECHANICUS unit is within 6\" of this model, that unit has the Stealth ability.",
                    "showAbility": true,
                    "showDescription": true
                  }
                ],
                "showAbility": true
              }
            ],
